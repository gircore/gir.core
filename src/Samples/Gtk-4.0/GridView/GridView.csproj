  <ItemGroup>
    <ProjectReference Include="..\..\..\Libs\Gtk-4.0\Gtk-4.0.csproj" />
  </ItemGroup>

  <ItemGroup>
   <None Include="$(ProjectDir)Resources\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

